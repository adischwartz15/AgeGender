# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Data & artifacts (never commit real datasets or trained weights)
data/raw/*
data/processed/*
data/splits/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/splits/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
outputs/*
!outputs/.gitkeep

# Kaggle credentials - never commit
kaggle.json
.kaggle/

# Env
.env
*.local

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Auto-generated reports (produced by scripts/generate_architecture_report.py,
# scripts/generate_final_report.py, or scripts/export_report.py from outputs/
# artifacts -- not source)
docs/architecture_analysis_generated.md
docs/final_results_report.md

# Logs
*.log
